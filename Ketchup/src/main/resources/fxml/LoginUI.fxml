<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>

<!--
    LoginUI.fxml
    Netflix-themed login screen for Ketchup.
    Controller: com.ducksabervn.projects.ketchup.frontend.controller.LoginUIController
-->
<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.ducksabervn.projects.ketchup.frontend.LoginUIController"
        styleClass="root-pane"
        stylesheets="@../css/LoginUI.css">

    <VBox styleClass="bg-overlay" alignment="CENTER">

        <!-- Login Card -->
        <VBox styleClass="login-card" alignment="CENTER_LEFT" spacing="0">

            <!-- Brand -->
            <Label styleClass="brand-logo" text="KETCHUP" />
            <Label styleClass="brand-tagline" text="Sign in to continue" />

            <VBox spacing="0" style="-fx-padding: 18 0 0 0;">

                <!-- Email -->
                <Label styleClass="field-label" text="Email"/>
                <MFXTextField
                        fx:id="emailField"
                        styleClass="mfx-field"
                        promptText="Enter your email"/>

                <!-- Password -->
                <Label styleClass="field-label" text="Password" style="-fx-padding: 18 0 7 0;"/>
                <MFXPasswordField
                        fx:id="passwordField"
                        styleClass="mfx-field"
                        promptText="Enter your password" />

                <!-- Role -->
                <Label styleClass="field-label" text="Sign in as" style="-fx-padding: 18 0 7 0;"/>
                <MFXComboBox
                        fx:id="roleComboBox"
                        styleClass="mfx-combo"
                        promptText="Select role" />

                <!-- Error -->
                <Label
                        fx:id="errorLabel"
                        styleClass="error-label"
                        text=""
                        wrapText="true"
                        style="-fx-padding: 14 0 0 0;" />

                <!-- Sign In -->
                <MFXButton
                        fx:id="loginButton"
                        styleClass="btn-primary"
                        text="Sign In"
                        onAction="#handleLogin"
                        maxWidth="Infinity"
                        style="-fx-padding: 12 0 12 0; -fx-margin: 22 0 0 0;" />

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 18 0 18 0;">
                    <VBox styleClass="divider-line" HBox.hgrow="ALWAYS" />
                    <Label styleClass="divider-text" text="OR" />
                    <VBox styleClass="divider-line" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Register -->
                <MFXButton
                        fx:id="registerButton"
                        styleClass="btn-secondary"
                        text="Create New Account"
                        onAction="#handleRegister"
                        maxWidth="Infinity" />
            </VBox>
        </VBox>
    </VBox>
</StackPane>
